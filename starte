-- найти убийцу
local function getNearestMurderer()

	local camera = workspace.CurrentCamera
	local cameraPos = camera.CFrame.Position

	local closest
	local dist = math.huge

	for _,plr in pairs(Players:GetPlayers()) do

		if plr ~= player and getRole(plr) == "Murderer" and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then

			local d = (plr.Character.HumanoidRootPart.Position - cameraPos).Magnitude

			if d < dist then
				dist = d
				closest = plr
			end

		end

	end

	return closest
end

-- Silent Aim (ПК + телефон)
UIS.InputBegan:Connect(function(input,gp)

	if gp then return end
	if not silentAimEnabled then return end

	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then

		local character = player.Character
		if not character then return end

		local tool = character:FindFirstChildOfClass("Tool")
		if not tool or tool.Name ~= "Gun" then return end

		local target = getNearestMurderer()
		if not target then return end

		local part = target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")

		if part then
			local mouse = player:GetMouse()
			mouse.Hit = CFrame.new(part.Position)
			tool:Activate()
		end

	end

end)

refreshAllESP()
